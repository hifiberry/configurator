#!/usr/bin/make -f

# The tests/ suite is pytest-style and depends on runtime modules
# (cryptography, etc.) that aren't present in the minimal build chroot; run
# it in CI/dev via pytest instead of at packaging time.
export PYBUILD_DISABLE=test

# Inject the virtualenv sequence into dh
%:
	dh $@ --with virtualenv

# Override the default installation to use dh_virtualenv
override_dh_virtualenv:
	dh_virtualenv --builtin-venv --pypi-url https://pypi.org

# Prevent standard python build tools from running globally
override_dh_auto_install:
	@echo "Skipping standard auto install, dh_virtualenv handles this."

#%:
#	dh $@ --buildsystem=pybuild
